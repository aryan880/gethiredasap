{
  "name": "gethiredasap",
  "private": true,
  "scripts": {
    "build": "turbo run build --filter=web",
    "build:all": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "postinstall": "prisma generate --schema apps/api/prisma/schema.prisma",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.8.20",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "npm@10.9.2",
  "workspaces": [
    "apps/api",
    "apps/web",
    "packages/*"
  ]
}
