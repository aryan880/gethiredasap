generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Tier {
  FREE
  PRO
  PREMIUM
}

enum Channel {
  PUSH
  TELEGRAM
  EMAIL
  IN_APP
}

enum ApplicationStatus {
  NEW
  SAVED
  APPLIED
  INTERVIEW
  OFFER
  REJECTED
}

enum ResumeFamily {
  SOFTWARE
  IT_SUPPORT
  SYSTEMS_ANALYST
  GENERAL
  CUSTOM
}

enum CandidateDocumentKind {
  MASTER_RESUME
  TAILORED_RESUME
  COVER_LETTER
  JOB_DESCRIPTION
  MATCH_REPORT
  RECRUITER_OUTREACH
  APPLICATION_ANSWERS
  OTHER
}

enum DiscoveryOrigin {
  AI_JOB_HUNTER
  CHATGPT_WORK
  BOTH
  MANUAL
}

enum JobVerificationStatus {
  UNVERIFIED
  VERIFIED_OPEN
  UNCERTAIN
  CLOSED
  REJECTED
}

enum JobUrlProvenance {
  EMPLOYER_ATS
  EMPLOYER_CAREERS
  AGGREGATOR_DETAIL
  REDIRECT
  UNKNOWN
}

enum ApplicationPackageStatus {
  NEEDS_REVIEW
  READY_FOR_WORK
  GENERATING
  READY_FOR_REVIEW
  APPROVED
  APPLIED
  FAILED
  ARCHIVED
}

enum JobContactType {
  RECRUITER
  HIRING_MANAGER
  TEAM_MEMBER
  ALUMNI
  GENERAL
}

enum OutreachChannel {
  EMAIL
  LINKEDIN
  OTHER
}

enum OutreachStatus {
  DRAFT
  APPROVED
  SENT
  REPLIED
  ARCHIVED
}

model User {
  id                    String                 @id @default(cuid())
  email                 String                 @unique
  passwordHash          String
  name                  String
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  resumeText            String?
  resumeUrl             String?
  activeResumeFamily    ResumeFamily?
  threshold             Int                    @default(15)
  intervalMinutes       Int                    @default(15)
  isActive              Boolean                @default(true)
  isAdmin               Boolean                @default(false)
  tier                  Tier                   @default(FREE)
  tierExpiresAt         DateTime?
  stripeCustomerId      String?
  pushToken             String?
  telegramId            String?
  searches              JobSearch[]
  savedSearches         SavedSearch[]
  matches               JobMatch[]
  alerts                Alert[]
  inviteCodes           InviteCode[]
  applications          JobApplication[]
  documents             CandidateDocument[]
  applicationPackages   ApplicationPackage[]
  jobContacts           JobContact[]
  outreachDrafts        OutreachDraft[]
  jobSourceObservations JobSourceObservation[]

  @@map("users")
}

model CandidateDocument {
  id                  String                       @id @default(cuid())
  userId              String
  name                String
  fileName            String
  mimeType            String
  kind                CandidateDocumentKind
  resumeFamily        ResumeFamily?
  byteSize            Int
  sha256              String
  ciphertext          Bytes
  iv                  Bytes
  authTag             Bytes
  textCiphertext      Bytes?
  textIv              Bytes?
  textAuthTag         Bytes?
  textSha256          String?
  textLength          Int?
  textExtractedAt     DateTime?
  textExtractionError String?
  isMaster            Boolean                      @default(false)
  libraryFileId       String?
  libraryPath         String?
  createdAt           DateTime                     @default(now())
  updatedAt           DateTime                     @updatedAt
  user                User                         @relation(fields: [userId], references: [id], onDelete: Cascade)
  packageLinks        ApplicationPackageDocument[]

  @@index([userId, kind, isMaster])
  @@index([userId, resumeFamily])
  @@map("candidate_documents")
}

model ApplicationPackage {
  id                       String                       @id @default(cuid())
  userId                   String
  source                   String
  externalJobId            String
  canonicalJobKey          String
  title                    String
  company                  String
  location                 String?
  jobUrl                   String
  applicationUrl           String?
  canonicalEmployerUrl     String?
  sourceNativeId           String?
  requisitionId            String?
  urlProvenance            JobUrlProvenance             @default(UNKNOWN)
  applicationUrlVerifiedAt DateTime?
  discoveredBy             DiscoveryOrigin              @default(AI_JOB_HUNTER)
  verificationStatus       JobVerificationStatus        @default(UNVERIFIED)
  verificationEvidence     Json?
  verifiedAt               DateTime?
  publishedAt              DateTime?
  firstSeenAt              DateTime?
  fitScore                 Int?
  freshnessScore           Int?
  scoringPolicyVersion     String?
  scoreBreakdown           Json?
  hardBlockers             Json?
  matchEvidence            Json?
  roleFamily               ResumeFamily                 @default(GENERAL)
  status                   ApplicationPackageStatus     @default(NEEDS_REVIEW)
  workNotes                String?                      @db.Text
  missedByAutomation       Boolean                      @default(false)
  automationMissReason     String?
  automationMissNotes      String?                      @db.Text
  automationReviewedAt     DateTime?
  alertedAt                DateTime?
  libraryFolderId          String?
  libraryPath              String?
  createdAt                DateTime                     @default(now())
  updatedAt                DateTime                     @updatedAt
  user                     User                         @relation(fields: [userId], references: [id], onDelete: Cascade)
  documents                ApplicationPackageDocument[]
  contacts                 JobContact[]
  outreachDrafts           OutreachDraft[]
  sourceObservations       JobSourceObservation[]

  @@unique([userId, source, externalJobId])
  @@unique([userId, canonicalJobKey])
  @@index([userId, status, updatedAt])
  @@index([userId, verificationStatus, fitScore])
  @@index([userId, discoveredBy, missedByAutomation])
  @@map("application_packages")
}

model JobSourceObservation {
  id                       String             @id @default(cuid())
  userId                   String
  packageId                String
  source                   String
  externalJobId            String
  sourceNativeId           String?
  requisitionId            String?
  detailUrl                String
  applicationUrl           String?
  urlProvenance            JobUrlProvenance   @default(UNKNOWN)
  applicationUrlVerifiedAt DateTime?
  firstSeenAt              DateTime           @default(now())
  lastSeenAt               DateTime           @default(now())
  rawMetadata              Json?
  createdAt                DateTime           @default(now())
  updatedAt                DateTime           @updatedAt
  user                     User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  package                  ApplicationPackage @relation(fields: [packageId], references: [id], onDelete: Cascade)

  @@unique([userId, source, externalJobId])
  @@index([packageId, lastSeenAt])
  @@index([userId, requisitionId])
  @@map("job_source_observations")
}

model ApplicationPackageDocument {
  id         String                @id @default(cuid())
  packageId  String
  documentId String
  purpose    CandidateDocumentKind
  createdAt  DateTime              @default(now())
  package    ApplicationPackage    @relation(fields: [packageId], references: [id], onDelete: Cascade)
  document   CandidateDocument     @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([packageId, documentId])
  @@index([packageId, purpose])
  @@map("application_package_documents")
}

model JobContact {
  id                     String             @id @default(cuid())
  userId                 String
  packageId              String
  name                   String
  title                  String?
  company                String?
  contactType            JobContactType     @default(GENERAL)
  profileUrl             String?
  verifiedEmail          String?
  emailVerificationUrl   String?
  verificationConfidence Int?
  recommendedOrder       Int                @default(0)
  notes                  String?            @db.Text
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt
  user                   User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  package                ApplicationPackage @relation(fields: [packageId], references: [id], onDelete: Cascade)
  outreachDrafts         OutreachDraft[]

  @@index([userId, packageId, recommendedOrder])
  @@map("job_contacts")
}

model OutreachDraft {
  id          String             @id @default(cuid())
  userId      String
  packageId   String
  contactId   String?
  channel     OutreachChannel
  subject     String?
  body        String             @db.Text
  status      OutreachStatus     @default(DRAFT)
  generatedBy String             @default("CHATGPT_WORK")
  sentAt      DateTime?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  package     ApplicationPackage @relation(fields: [packageId], references: [id], onDelete: Cascade)
  contact     JobContact?        @relation(fields: [contactId], references: [id], onDelete: SetNull)

  @@index([userId, packageId, status])
  @@map("outreach_drafts")
}

model JobApplication {
  id             String            @id @default(cuid())
  userId         String
  externalJobId  String
  source         String?
  title          String?
  company        String?
  location       String?
  jobUrl         String?
  status         ApplicationStatus @default(NEW)
  recruiterName  String?
  recruiterEmail String?
  followUpNotes  String?           @db.Text
  appliedDate    DateTime?
  createdAt      DateTime          @default(now())
  lastUpdated    DateTime          @updatedAt
  user           User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, externalJobId])
  @@index([userId, status])
  @@map("job_applications")
}

model JobSearch {
  id        String   @id @default(cuid())
  userId    String
  role      String
  location  String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("job_searches")
}

model SavedSearch {
  id                      String             @id @default(cuid())
  userId                  String
  name                    String
  keywords                String
  location                String?
  category                String?
  workMode                String?
  minimumMatchScore       Int                @default(0)
  companies               Json?
  sources                 Json?
  frequency               String             @default("daily")
  matchMode               String             @default("balanced")
  excludeSeniorRoles      Boolean            @default(false)
  preferJuniorRoles       Boolean            @default(false)
  excludeContract         Boolean            @default(false)
  excludeStaffingAgencies Boolean            @default(false)
  enabled                 Boolean            @default(true)
  lastEvaluatedAt         DateTime?
  createdAt               DateTime           @default(now())
  updatedAt               DateTime           @updatedAt
  user                    User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  alertEvents             SavedSearchAlert[]

  @@index([userId, enabled])
  @@map("saved_searches")
}

model SavedSearchAlert {
  id            String      @id @default(cuid())
  savedSearchId String
  externalJobId String
  payload       Json
  matchedAt     DateTime    @default(now())
  notifiedAt    DateTime?
  savedSearch   SavedSearch @relation(fields: [savedSearchId], references: [id], onDelete: Cascade)

  @@unique([savedSearchId, externalJobId])
  @@index([savedSearchId, matchedAt])
  @@map("saved_search_alerts")
}

model Job {
  id          String     @id
  title       String
  company     String
  location    String
  postedAt    DateTime?
  link        String
  description String?    @db.Text
  salary      String?
  scrapedAt   DateTime   @default(now())
  matches     JobMatch[]

  @@map("jobs")
}

model JobMatch {
  id            String    @id @default(cuid())
  userId        String
  jobId         String
  score         Float
  expLabel      String?
  isEarlyCareer Boolean   @default(false)
  seenAt        DateTime  @default(now())
  alertedAt     DateTime?
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  job           Job       @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([userId, jobId])
  @@map("job_matches")
}

model Alert {
  id       String    @id @default(cuid())
  userId   String
  jobId    String
  channel  Channel
  sentAt   DateTime  @default(now())
  openedAt DateTime?
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("alerts")
}

model InviteCode {
  id              String    @id @default(cuid())
  code            String    @unique
  tier            Tier
  userId          String?
  createdBy       String
  stripePaymentId String?
  expiresAt       DateTime?
  usedAt          DateTime?
  createdAt       DateTime  @default(now())
  user            User?     @relation(fields: [userId], references: [id])

  @@map("invite_codes")
}
