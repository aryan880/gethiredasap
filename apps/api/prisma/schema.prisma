generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
   url     = env("DATABASE_URL")
}

enum Tier {
  FREE
  PRO
  PREMIUM
}

enum Channel {
  PUSH
  TELEGRAM
  EMAIL
  IN_APP
}

enum ApplicationStatus {
  NEW
  SAVED
  APPLIED
  INTERVIEW
  OFFER
  REJECTED
}

model User {
  id               String      @id @default(cuid())
  email            String      @unique
  passwordHash     String
  name             String
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  resumeText       String?
  resumeUrl        String?
  threshold        Int         @default(15)
  intervalMinutes  Int         @default(15)
  isActive         Boolean     @default(true)
  isAdmin          Boolean     @default(false)
  tier             Tier        @default(FREE)
  tierExpiresAt    DateTime?
  stripeCustomerId String?
  pushToken        String?
  telegramId       String?
  searches         JobSearch[]
  savedSearches    SavedSearch[]
  matches          JobMatch[]
  alerts           Alert[]
  inviteCodes      InviteCode[]
  applications     JobApplication[]

  @@map("users")
}

model JobApplication {
  id              String            @id @default(cuid())
  userId          String
  externalJobId   String
  source          String?
  title           String?
  company         String?
  location        String?
  jobUrl          String?
  status          ApplicationStatus @default(NEW)
  recruiterName   String?
  recruiterEmail  String?
  followUpNotes   String?           @db.Text
  appliedDate     DateTime?
  createdAt       DateTime          @default(now())
  lastUpdated     DateTime          @updatedAt
  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, externalJobId])
  @@index([userId, status])
  @@map("job_applications")
}

model JobSearch {
  id        String   @id @default(cuid())
  userId    String
  role      String
  location  String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("job_searches")
}

model SavedSearch {
  id                String             @id @default(cuid())
  userId            String
  name              String
  keywords          String
  location          String?
  category          String?
  workMode          String?
  minimumMatchScore Int                @default(0)
  companies         Json?
  sources           Json?
  frequency         String             @default("daily")
  matchMode         String             @default("balanced")
  excludeSeniorRoles Boolean           @default(false)
  preferJuniorRoles Boolean            @default(false)
  excludeContract   Boolean            @default(false)
  excludeStaffingAgencies Boolean      @default(false)
  enabled           Boolean            @default(true)
  lastEvaluatedAt   DateTime?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  alertEvents       SavedSearchAlert[]

  @@index([userId, enabled])
  @@map("saved_searches")
}

model SavedSearchAlert {
  id            String      @id @default(cuid())
  savedSearchId String
  externalJobId String
  payload       Json
  matchedAt     DateTime    @default(now())
  notifiedAt    DateTime?
  savedSearch   SavedSearch @relation(fields: [savedSearchId], references: [id], onDelete: Cascade)

  @@unique([savedSearchId, externalJobId])
  @@index([savedSearchId, matchedAt])
  @@map("saved_search_alerts")
}

model Job {
  id          String     @id
  title       String
  company     String
  location    String
  postedAt    DateTime?
  link        String
  description String?    @db.Text
  salary      String?
  scrapedAt   DateTime   @default(now())
  matches     JobMatch[]

  @@map("jobs")
}

model JobMatch {
  id            String    @id @default(cuid())
  userId        String
  jobId         String
  score         Float
  expLabel      String?
  isEarlyCareer Boolean   @default(false)
  seenAt        DateTime  @default(now())
  alertedAt     DateTime?
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  job           Job       @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([userId, jobId])
  @@map("job_matches")
}

model Alert {
  id       String   @id @default(cuid())
  userId   String
  jobId    String
  channel  Channel
  sentAt   DateTime @default(now())
  openedAt DateTime?
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("alerts")
}

model InviteCode {
  id              String    @id @default(cuid())
  code            String    @unique
  tier            Tier
  userId          String?
  createdBy       String
  stripePaymentId String?
  expiresAt       DateTime?
  usedAt          DateTime?
  createdAt       DateTime  @default(now())
  user            User?     @relation(fields: [userId], references: [id])

  @@map("invite_codes")
}
