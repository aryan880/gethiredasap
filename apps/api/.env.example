# Express API
PORT=3001
NODE_ENV=development
CLIENT_URL=http://localhost:3000

# Local Docker Compose defaults; replace for other environments
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/gethiredasap
REDIS_URL=redis://localhost:6379

# Authentication: generate long, unique values
JWT_SECRET=replace-with-a-32-plus-character-access-secret
JWT_REFRESH_SECRET=replace-with-a-32-plus-character-refresh-secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# AI Job Hunter and NLP internal services
JOB_HUNTER_URL=http://localhost:8010
JOB_HUNTER_API_KEY=replace-with-a-32-plus-character-shared-secret
NLP_URL=http://localhost:8002
NLP_API_KEY=replace-with-a-different-32-plus-character-shared-secret
ENABLE_LEGACY_SCRAPER=false

# Private document vault: generate with `openssl rand -base64 32`
DOCUMENT_ENCRYPTION_KEY=replace-with-a-base64-encoded-32-byte-key

# Legacy scraper service is optional and disabled by default
SCRAPER_URL=http://localhost:8001

# Stripe test-mode values only for local development
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
STRIPE_PRO_PRICE_ID=price_replace_me
STRIPE_PREMIUM_PRICE_ID=price_replace_me
